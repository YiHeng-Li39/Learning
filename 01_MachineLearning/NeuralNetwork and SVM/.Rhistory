total <- total + (alpha + beta * j / r) * f_X[j] * f_S[r - j + 1]
}
f_S[r + 1] <- total  # 存储计算结果
}
# 4. 构建2行22列的数据框
# 第一行：行名"S取值"，内容为0到20
# 第二行：行名"概率"，内容为对应的概率值
row1 <- c("S取值", as.character(0:r_max))  # 第一行数据（含标签）
row2 <- c("概率", as.character(round(f_S, 6)))  # 第二行数据（含标签，保留6位小数）
# 转换为矩阵后再转为数据框
result_matrix <- rbind(row1, row2)
result_df <- as.data.frame(result_matrix, stringsAsFactors = FALSE)
# 设置列名（第一列名为"S"，后续为0到20）
colnames(result_df) <- c("S", as.character(0:r_max))
# 5. 输出结果
print("S的分布列（2行22列）：")
print(result_df, row.names = TRUE)
# 牛顿法迭代计算调整系数 R_k
# 初始化
R <- numeric(11)
R[1] <- 0.3  # R0 = 0.3
# 定义 A(r) 和 A'(r)
A <- function(r) {
if (abs(r) < 1e-10) return(0)  # 避免除零，r接近0时A(r)=0
(exp(r) - 1)/r - 1 - 1.1 * r
}
A_prime <- function(r) {
if (abs(r) < 1e-10) return(0.5 - 1.1)  # r→0时，极限为 0.5 - 1.1
(r * exp(r) - (exp(r) - 1))/r^2 - 1.1
}
# 牛顿法迭代
for (k in 2:11) {
R[k] <- R[k-1] - A(R[k-1]) / A_prime(R[k-1])
}
# 构造数据框输出
result_df <- data.frame(t(R))
colnames(result_df) <- paste0("R", 0:10)
rownames(result_df) <- "Newton迭代结果"
# 打印结果
print(result_df)
# 牛顿法迭代计算调整系数 R_k
# 初始值
R <- numeric(11)
R[1] <- 0.3  # R0 = 0.3
# 定义 A(r) 和 A'(r)
A <- function(r) {
if (abs(r) < 1e-12) return(0)  # r→0 时，A(r)→0
(exp(r) - 1)/r - 1 - 0.55 * r
}
A_prime <- function(r) {
if (abs(r) < 1e-12) return(0.5 - 0.55)  # r→0 时，极限为 0.5 - 0.55
(r * exp(r) - (exp(r) - 1))/r^2 - 0.55
}
# 牛顿法迭代
for (k in 2:11) {
R[k] <- R[k-1] - A(R[k-1]) / A_prime(R[k-1])
}
# 构造数据框输出
result_df <- data.frame(t(R))
colnames(result_df) <- paste0("R", 0:10)
rownames(result_df) <- "Rk"
# 打印结果
print(result_df, digits = 8)
