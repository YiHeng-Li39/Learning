Mktcap = last(Mktcap),         # 月末市值
Clsprc = last(Clsprc),         # 月末收盘价
Ret = prod(1 + Ret) - 1,       # 月度复利回报
Vol_Shares = sum(Dnshrtrd, na.rm=TRUE), # 月总成交量
.groups = "drop"
)
