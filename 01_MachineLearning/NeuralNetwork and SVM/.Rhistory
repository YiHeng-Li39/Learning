# ==============================================================================
# 步骤 1: 构建 CH-4 模型的 PMO (情绪/换手率) 因子
# ==============================================================================
# 1. 加载包
library(data.table)
library(tidyverse)
library(lubridate)
library(zoo) # 用于计算滚动平均
# 2. 读取数据 (使用你的本地路径)
cat("正在读取数据，请稍候...\n")
path1 <- "C:/Users/李刚/Desktop/TRD_Dalyr.csv"
path2 <- "C:/Users/李刚/Desktop/TRD_Dalyr1.csv"
df_raw <- rbind(fread(path1), fread(path2))
# 3. 数据清洗与换手率计算
# 这里的核心逻辑是：换手率 = 成交量 / 总股本
# 数据字典里: Dsmvtll 是千元单位的总市值, Clsprc 是收盘价
cat("正在清洗数据并计算换手率...\n")
df_clean <- df_raw %>%
# 筛选需要的列
select(Stkcd, Trddt, Dnshrtrd, Dsmvtll, Clsprc, Dretwd) %>%
mutate(
Stkcd = sprintf("%06d", Stkcd),            # 补齐股票代码为6位
Trddt = as.Date(Trddt),                    # 转为日期格式
# 计算总股本 (股) = 总市值(元) / 收盘价(元)
# 注意 Dsmvtll 单位是千，所以要 * 1000
TotalShares = (as.numeric(Dsmvtll) * 1000) / as.numeric(Clsprc),
# 计算日换手率 = 成交量 / 总股本
Turnover = as.numeric(Dnshrtrd) / TotalShares,
Mret = as.numeric(Dretwd)                  # 日收益率
) %>%
filter(!is.na(Turnover), !is.na(Mret), Turnover > 0) %>%
arrange(Stkcd, Trddt)
# 4. 计算 PMO 因子构建所需的指标
# 逻辑：
# (1) 计算过去N天的平均换手率 (通常用20天或一个月作为短期，或者更长)
# (2) Liu, Stambaugh, Yuan (2019) 使用“异常换手率”
# 这里我们简化复现：计算月度平均换手率，然后按月分组
cat("正在计算月度换手率...\n")
# 将日度数据聚合为月度数据
df_monthly <- df_clean %>%
mutate(Month = floor_date(Trddt, "month")) %>%
group_by(Stkcd, Month) %>%
summarise(
# 月平均换手率
Avg_Turnover = mean(Turnover, na.rm = TRUE),
# 月累积收益率 (用于计算因子收益)
Mkt_Cap_End = last(Dsmvtll) * 1000, # 月末市值
Monthly_Ret = prod(1 + Mret) - 1,   # 复利计算月收益
.groups = "drop"
)
# 5. 构建 PMO 因子 (Pessimistic Minus Optimistic)
# 逻辑：低换手率(Pessimistic) - 高换手率(Optimistic)
# 注意：在中国，高换手率通常预示未来低回报，所以我们买入低换手，卖出高换手
cat("正在构建投资组合并计算因子收益...\n")
pmo_factor <- df_monthly %>%
group_by(Month) %>%
mutate(
# 按换手率分3组：Low(30%), Mid(40%), High(30%)
rank = ntile(Avg_Turnover, 3),
group = case_when(
rank == 1 ~ "Low_Turnover",
rank == 3 ~ "High_Turnover",
TRUE ~ "Mid"
)
) %>%
# 计算每组的市值加权平均收益率
group_by(Month, group) %>%
summarise(
ret = weighted.mean(Monthly_Ret, w = Mkt_Cap_End, na.rm = TRUE),
.groups = "drop"
) %>%
pivot_wider(names_from = group, values_from = ret) %>%
mutate(
# PMO 因子 = 低换手组收益 - 高换手组收益
PMO = Low_Turnover - High_Turnover
) %>%
select(Month, PMO) %>%
arrange(Month)
# 6. 保存结果与查看
print("PMO 因子构建完成！前5行如下：")
print(head(pmo_factor))
# 保存为 CSV，供后续回归使用
write.csv(pmo_factor, "C:/Users/李刚/Desktop/My_PMO_Factor.csv", row.names = FALSE)
cat("文件已保存至: C:/Users/李刚/Desktop/My_PMO_Factor.csv\n")
