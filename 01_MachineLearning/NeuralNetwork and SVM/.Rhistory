Stkcd = sprintf("%06d", as.numeric(Stkcd)), # 统一转为6位字符串代码
Trddt = as.Date(Trddt),
Mktcap = as.numeric(Dsmvtll) * 1000,        # 千元 -> 元
Ret = as.numeric(Dretwd),
Month = floor_date(Trddt, "month")
) %>%
filter(!is.na(Mktcap), !is.na(Ret))
# B. 读取财务数据 (PRI_Basic) - 包含扣非净利润 (Npnoc)
