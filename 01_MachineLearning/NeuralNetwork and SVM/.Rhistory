cat("Step 1: 正在读取数据，这可能需要一点时间...\n")
# A. 读取交易数据 (TRD_Dalyr) - 包含市值、回报率、成交量
path_trd1 <- "C:/Users/李刚/Desktop/TRD_Dalyr.csv"
